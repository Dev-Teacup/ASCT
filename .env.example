# TiDB Cloud Starter instance: act2, AWS N. Virginia (us-east-1).
# Copy DB_HOST, DB_USER, and DB_PASS from TiDB Cloud's Connect dialog.
DB_HOST=REPLACE_WITH_TIDB_HOST
DB_PORT=4000
DB_NAME=asct
DB_USER=REPLACE_WITH_TIDB_USER
DB_PASS=REPLACE_WITH_TIDB_PASSWORD
DB_CHARSET=utf8mb4
DB_SSL_MODE=required
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
DB_SSL_VERIFY_SERVER_CERT=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=ASCT Portal
ASCT_APP_NAME=ASCT Portal
ASCT_APP_BASE_URL=https://asct-mcf5.onrender.com
